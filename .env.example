# ─────────────────────────────────────────────────────────────
# AOI Team Hub — environment template. Copy to .env.local and fill.
# ─────────────────────────────────────────────────────────────

# Public Supabase config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Server-only Supabase service role key — NEVER expose to the client.
# Used by admin Edge Functions / route handlers and the seed script.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Canonical site URL (used for auth redirects, absolute links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Upstash Redis for distributed rate limiting.
# If unset, rate limiting falls back to an in-memory limiter (single instance).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret used to sign the short-lived legacy "bridge token" handed to wrapped
# HTML tools (e.g. the reconciler) via AOI_SESSION_SHARED. Generate a random
# 32+ char string. This is NOT the Supabase JWT.
LEGACY_BRIDGE_SECRET=change-me-to-a-long-random-string

# Seed script inputs (used once by scripts/seed-super-admin.ts)
SEED_SUPERADMIN_EMAIL=admin@airoceanline.com.eg
SEED_SUPERADMIN_PASSWORD=Aoi@2026-Change-Me
SEED_SUPERADMIN_USERNAME=admin
SEED_SUPERADMIN_NAME=AOI Super Admin
